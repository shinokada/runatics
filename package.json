{
  "name": "runatics",
  "version": "0.3.0",
  "main": "dist/index.js",
  "description": "A simple Google analyticscomponent for Svelte Runes project",
  "author": {
    "name": "Shinichi Okada",
    "email": "connect@codewithshin.com",
    "url": "https://blog.codewithshin.com"
  },
  "bugs": "https://github.com/shinokada/runatics/issues",
  "homepage": "https://runatics.codewithshin.com/",
  "license": "MIT",
  "keywords": [
    "svelte",
    "sveltekit",
    "google analytics",
    "analytics",
    "runes"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shinokada/runatics.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "gen:exports": "svelte-lib-helpers exports",
    "gen:docs5": "svelte-lib-helpers docs5FromType",
    "gen:compo-data": "svelte-lib-helpers compo-data",
    "copy:package": "svelte-lib-helpers package",
    "lib-helpers": "pnpm format && pnpm prepack && pnpm copy:package",
    "ch": "npx changeset",
    "cv": "npx changeset version",
    "cp": "npx changeset publish"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.55.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "flowbite-svelte": "^1.33.0",
    "globals": "^17.4.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.18",
    "runes-meta-tags": "^0.5.0",
    "runes-webkit": "^0.12.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "svelte-lib-helpers": "^0.4.31",
    "svelte-rune-highlight": "^0.12.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.2"
  }
}
